@model API.Services.Email.Models.WinnerEmailModel
@{
    Layout = "~/Views/Emails/_Layout.cshtml";
    var font = "-apple-system,'Segoe UI',system-ui,Roboto,Arial,sans-serif";
}

<!-- Winner badge (mirrors the site's green success accent) -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 20px;">
    <tr>
        <td style="background-color:#14251b;border:1px solid #22c55e;border-radius:6px;padding:4px 11px;">
            <span style="font-family:@font;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#22c55e;">Auction won</span>
        </td>
    </tr>
</table>

<h1 style="margin:0 0 8px;font-family:@font;font-size:24px;font-weight:700;line-height:1.25;color:#ffffff;">Congratulations!</h1>
<p style="margin:0 0 24px;font-family:@font;font-size:15px;line-height:1.6;color:#9ca3af;">
    You placed the winning bid on <strong style="color:#ffffff;font-weight:600;">@Model.ItemName</strong>.
</p>

<!-- Winning-bid panel (deepest surface + hairline border, like the auction card's pricing block) -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a1a1a;border:1px solid #1f2937;border-radius:10px;margin:0 0 28px;">
    <tr>
        <td style="padding:20px 24px;">
            <div style="font-family:@font;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#6b7280;">Winning bid</div>
            <div style="font-family:@font;font-size:28px;font-weight:700;color:#ffffff;padding-top:6px;">@Model.Amount.ToString("C")</div>
        </td>
    </tr>
</table>

<!-- Primary CTA (bulletproof button in the site's red) -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
    <tr>
        <td align="center" bgcolor="#ff4742" style="border-radius:8px;">
            <a href="@Model.AuctionUrl" target="_blank" style="display:inline-block;padding:13px 32px;font-family:@font;font-size:14px;font-weight:700;color:#ffffff;text-decoration:none;border-radius:8px;">Complete your payment &rarr;</a>
        </td>
    </tr>
</table>

<p style="margin:0;font-family:@font;font-size:13px;line-height:1.6;color:#6b7280;">
    Payment secures the item and releases it to you. If the button doesn't work, paste this link into your browser:<br>
    <a href="@Model.AuctionUrl" style="color:#ff4742;text-decoration:none;word-break:break-all;">@Model.AuctionUrl</a>
</p>
